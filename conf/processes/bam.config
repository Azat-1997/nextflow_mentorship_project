process {
    withName:ALIGN {
        container = 'quay.io/biocontainers/bwa:0.7.17--he4a0461_11'
        cpus = 4
    }

    withName:CONVERT2SORTED_BAM {
        container = 'broadinstitute/gatk'
        cpus = 4
    }

    withName:INDEX_BAM {
        container = 'broadinstitute/gatk'
        cpus = 4
    }

    withName:ADD_RG {
        container = 'broadinstitute/gatk'
        cpus = 4
    }

    withName:INDEX_RG_BAM {
        container = 'broadinstitute/gatk'
        cpus = 4
    }
}